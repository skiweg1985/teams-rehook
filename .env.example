# Proxy listener ports (host -> HAProxy container 80/443)
PROXY_HTTP_PORT=8080
PROXY_HTTPS_PORT=8443

# Public app URLs exposed by the proxy / load balancer
APP_PUBLIC_BASE_URL=http://localhost:8080
FRONTEND_BASE_URL=http://localhost:8080
CORS_ORIGINS=http://localhost:8080

# Database
# Bare-process backend runs default to local SQLite (app.db). Docker Compose uses
# the bundled Postgres service unless DATABASE_URL is set to an external database.
# DATABASE_URL=postgresql+psycopg2://user:password@db.example.com:5432/teams_rehook
POSTGRES_DB=app
POSTGRES_USER=app
POSTGRES_PASSWORD=app
# POSTGRES_* initialize new bundled Postgres volumes only. For existing databases,
# rotate credentials in Postgres, then update DATABASE_URL and restart the backend.
# If production credentials contain URL-special characters, set DATABASE_URL
# explicitly with proper URL encoding instead of relying on the Compose fallback.

# Backend
WEBHOOK_MAX_PAYLOAD_BYTES=64000
LOG_RETENTION_DAYS=7
LOG_CLEANUP_INTERVAL_MINUTES=60
# The Docker Compose backend trusts X-Forwarded-For only from the controlled
# Compose network.
# For bare-process development without a trusted reverse proxy, keep this false.
TRUST_X_FORWARDED_FOR=false
TRUSTED_PROXY_IPS=

# Entra app registration (Bot Framework delivery and Microsoft Graph lookup)
# Required for BOT_DELIVERY_MODE=real
MS_APP_TENANT_ID=
MS_APP_CLIENT_ID=
MS_APP_CLIENT_SECRET=
BOTFRAMEWORK_SCOPE=https://api.botframework.com/.default
GRAPH_SCOPE=https://graph.microsoft.com/.default

# Delivery feature policy (defaults preserve existing behavior)
BOT_FRAMEWORK_ENABLED=true
GRAPH_LOOKUP_ENABLED=true
GRAPH_DELIVERY_ENABLED=true

# Teams Bot relay delivery (default: real)
# real: sends to Bot Framework; requires MS_APP_* credentials and BOT_DEFAULT_SERVICE_URL
# mock: simulates delivery without credentials (for local validation)
BOT_DELIVERY_MODE=real
BOT_DEFAULT_SERVICE_URL=

# Machine polling endpoint: GET /api/v1/monitoring/status
MONITORING_API_KEY=

# Secret material
# SETTINGS_ENC_KEY protects encrypted settings and delegated refresh material.
# If omitted, first startup creates a separate generated key in the database for
# local/simple shared-database deployments. Keep this stable across restarts.
# SETTINGS_ENC_KEY=
SESSION_COOKIE_NAME=teams_rehook_session
SESSION_TTL_HOURS=8
SESSION_SECURE_COOKIE=false
