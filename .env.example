# Proxy listener ports (host → HAProxy container 80/443)
PROXY_HTTP_PORT=8080
PROXY_HTTPS_PORT=8443

# Public app URLs exposed by the proxy / load balancer
APP_PUBLIC_BASE_URL=http://localhost:8080
FRONTEND_BASE_URL=http://localhost:8080
CORS_ORIGINS=http://localhost:8080

# Backend
DATABASE_URL=sqlite:///./app.db

# Session
SESSION_SECRET=change-me-session-secret
SESSION_COOKIE_NAME=codex_app_session
SESSION_TTL_HOURS=8
SESSION_SECURE_COOKIE=false

# Bootstrap admin user
BOOTSTRAP_ADMIN_EMAIL=admin@example.com
BOOTSTRAP_ADMIN_PASSWORD=change-me-admin-password
BOOTSTRAP_ADMIN_DISPLAY_NAME=App Admin
